# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=              # comma-separated for multiple groups

# Database
DB_PATH=/opt/otlc/data.db

# Optional AI summary (free via Google Gemini)
GEMINI_API_KEY=
ENABLE_AI_SUMMARY=false

# DFW Sincerity Index (irony scoring)
ENABLE_SINCERITY_INDEX=false
SINCERITY_SNIPPET_LIMIT=50

# Owl Town combined summary (aggregates multiple groups into one report)
OWL_TOWN_CHAT_IDS=              # comma-separated chat IDs to aggregate
OWL_TOWN_SEND_TO=               # chat ID where combined report is sent
OWL_TOWN_NAMES=                 # chat_id=Name pairs, comma-separated
